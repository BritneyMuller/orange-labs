---
import BaseLayout from '../layouts/BaseLayout.astro';
import Ticker from '../components/Ticker.astro';
import site from '../data/site.json';
import home from '../data/home.json';

const memberCountNumber = parseInt(site.memberCount, 10);

const icons: Record<string, string> = {
  flask:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 3h6M10 3v5l-5.5 9.5A2 2 0 0 0 6.2 21h11.6a2 2 0 0 0 1.7-3.5L14 8V3M7.5 15h9"/></svg>',
  terminal:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M7 9l4 3-4 3M13 15h4"/></svg>',
  network:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="6" cy="6" r="2.2"/><circle cx="18" cy="6" r="2.2"/><circle cx="12" cy="18" r="2.2"/><path d="M8.2 6h7.6M7 7.8l4 8M17 7.8l-4 8"/></svg>',
  library:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M3 7l2-3h14l2 3M10 12h4"/></svg>',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: home.faq.items.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---

<BaseLayout title={home.meta.title} description={home.meta.description}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />

  <header class="hero dotgrid">
    <div class="orb"></div>
    <div class="wrap">
      <div>
        <div class="status rise" style="--d:.05s;margin-bottom:1.6rem">
          <span class="dot"></span>{home.hero.statusPill}
        </div>
        <h1>
          {
            home.hero.headlineWords.map((word, i) => (
              <>
                {word.startsWith('*') ? (
                  <span class="wd" style={`--i:${i}`}>
                    <em>{word.replaceAll('*', '')}</em>
                  </span>
                ) : (
                  <span class="wd" style={`--i:${i}`}>
                    {word}
                  </span>
                )}{' '}
              </>
            ))
          }
        </h1>
        <p class="lede rise" style="--d:.75s">{home.hero.lede}</p>
        <div class="heroctas rise" style="--d:.9s">
          <div>
            <a class="btn btn-ember" href={home.hero.primaryCta.href}>{home.hero.primaryCta.label}</a>
            <p class="ctanote">{home.hero.primaryNote}</p>
          </div>
          <a class="btn btn-ghost" href={home.hero.secondaryCta.href}>{home.hero.secondaryCta.label}</a>
        </div>
        <div class="proof rise" style="--d:1.05s">
          <div class="avatars">
            <span style="background:var(--midnight)">JC</span>
            <span style="background:#8a5b2d">AM</span>
            <span style="background:var(--ember)">MC</span>
            <span style="background:#44608a">LG</span>
          </div>
          <p>
            <strong><span id="cnt" data-target={memberCountNumber}>{memberCountNumber}</span>+ marketers</strong>
            already inside, building with AI
          </p>
        </div>
      </div>
      <div class="bench rise" style="--d:.55s">
        <div class="ph ticks">{home.hero.photoLabel}</div>
        <div class="expcard">
          <div class="tag"><span class="dot"></span>{home.hero.expCard.tag}</div>
          <p>{home.hero.expCard.line}</p>
          <p class="who">{home.hero.expCard.who}</p>
        </div>
      </div>
    </div>
  </header>

  <Ticker />

  <section class="on-light">
    <div class="wrap split">
      <div class="ph ticks rv">{home.whatIs.photoLabel}</div>
      <div class="rv" style="--i:1">
        <div class="eyebrow">{home.whatIs.eyebrow}</div>
        <h2>{home.whatIs.heading}</h2>
        <p class="lede" style="margin-top:1.2rem">{home.whatIs.body}</p>
        <ul class="checks">
          {home.whatIs.checks.map((check) => <li>{check}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="midnight">
    <div class="wrap">
      <div class="centerhead rv">
        <div class="eyebrow">{home.problem.eyebrow}</div>
        <h2>{home.problem.heading}</h2>
      </div>
      <div class="cards3">
        {
          home.problem.cards.map((card, i) => (
            <div class="pcard ticks rv" style={`--i:${i}`}>
              <span class="chip">{card.chip}</span>
              <h3>{card.title}</h3>
              <p>{card.body}</p>
              <p class="answer">{card.answer}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="on-light">
    <div class="wrap">
      <div class="centerhead rv">
        <div class="eyebrow">{home.steps.eyebrow}</div>
        <h2>{home.steps.heading}</h2>
      </div>
      <div class="steps">
        {
          home.steps.items.map((step, i) => (
            <div class="step ticks rv" style={`--i:${i}`}>
              <div class="snum">Step 0{i + 1}</div>
              <h3>{step.title}</h3>
              <p set:html={step.html} />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="dotgrid">
    <div class="wrap">
      <div class="centerhead rv">
        <div class="eyebrow">{home.features.eyebrow}</div>
        <h2>{home.features.heading}</h2>
      </div>
      <div class="cards4">
        {
          home.features.cards.map((card, i) => (
            <div class="fcard rv" style={`--i:${i}`}>
              <div class="ficon" set:html={icons[card.icon]} />
              <span class="num">{card.num}</span>
              <h3>{card.title}</h3>
              <p set:html={card.html} />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="on-light">
    <div class="wrap split">
      <div class="rv">
        <div class="eyebrow">{home.origin.eyebrow}</div>
        <h2>{home.origin.heading}</h2>
        <div class="stars">{home.origin.stars}</div>
        <p class="lede">{home.origin.lede}</p>
        <ul class="checks">
          {home.origin.checks.map((check) => <li>{check}</li>)}
        </ul>
        <div style="margin-top:2rem">
          <a class="btn btn-ember" href={home.origin.cta.href}>{home.origin.cta.label}</a>
        </div>
      </div>
      <div class="ph ticks rv" style="--i:1">{home.origin.photoLabel}</div>
    </div>
  </section>

  <section class="midnight">
    <div class="wrap">
      <div class="centerhead rv">
        <div class="eyebrow">{home.results.eyebrow}</div>
        <h2>{home.results.heading}</h2>
      </div>
      <div class="quotecard ticks rv">
        <div>
          <blockquote>{home.results.quote}</blockquote>
          <p class="who"><strong>{home.results.who}</strong> · {home.results.whoDetail}</p>
        </div>
        <div class="ph" style="min-height:240px">{home.results.videoLabel}</div>
      </div>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="centerhead rv">
        <div class="eyebrow">{home.pricing.eyebrow}</div>
        <h2>{home.pricing.heading}</h2>
      </div>
      <div class="tiers">
        {
          home.pricing.tiers.map((tier, i) => (
            <div class={tier.hot ? 'tier hot rv' : 'tier rv'} style={`--i:${i}`}>
              {tier.hot && <span class="pop">Most popular</span>}
              <h3>{tier.name}</h3>
              <div class="price">
                {tier.price}
                {tier.per && <small>{tier.per}</small>}
              </div>
              <span class="risk">{tier.risk}</span>
              <p class="best">
                <strong>Best for:</strong> {tier.best}
              </p>
              <ul>
                {tier.includes.map((line) => <li>{line}</li>)}
              </ul>
              <a class={tier.hot ? 'btn btn-ember' : 'btn btn-iron'} href={tier.cta.href}>
                {tier.cta.label}
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="midnight">
    <div class="wrap">
      <div class="centerhead rv">
        <div class="eyebrow">{home.faq.eyebrow}</div>
        <h2>{home.faq.heading}</h2>
      </div>
      <div class="faq rv">
        {
          home.faq.items.map((item, i) => (
            <details>
              <summary>
                <span class="qn">Q.0{i + 1}</span>
                {item.q}
              </summary>
              <p>{item.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <div class="band">
    <div class="wrap">
      <h2 class="rv">{home.band.heading}</h2>
      <p class="rv" style="--i:1">{home.band.sub}</p>
      <div class="rv" style="--i:2">
        <a class="btn btn-iron" href={home.band.cta.href}>{home.band.cta.label}</a>
        <p class="ctanote">{home.band.note}</p>
      </div>
    </div>
  </div>
</BaseLayout>
